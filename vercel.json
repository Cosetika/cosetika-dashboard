{
  "functions": {
    "api/ventas.js": {
      "maxDuration": 15
    },
    "api/clientes.js": {
      "maxDuration": 15
    },
    "api/productos.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/login", "destination": "/public/login.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
